/* Linker version script: export ONLY the 7 C API symbols.
 * Hides ggml/ggml-cann/llama/qwen_common internals to avoid
 * symbol collision with future deps in consumer binaries
 * (Ascend API Bridge Contract §7 risk register).
 *
 * v1.2 (2026-04-20): dropped 9 primitive symbols (text_embed,
 * codec_embed, codec_head, generation_embed, reset_cache, forward,
 * predict_codes, decode_audio, extract_speaker) after upstream's
 * QwenTTS::generate() unification removed the TalkerLLM friend
 * accessors they required. SOVERSION stays 1 (VERSION bumped to 1.2.0)
 * — consumers that linked against the 16-symbol .so will see missing
 * symbols at startup; the only in-tree consumer (qwen-tts-ascend-sys)
 * uses qwen_tts_synthesize exclusively. */
QWEN_TTS_API_1.0 {
    global:
        qwen_tts_load;
        qwen_tts_free;
        qwen_tts_hidden_size;
        qwen_tts_vocab_size;
        qwen_tts_has_speaker_encoder;
        qwen_tts_synthesize;
        qwen_tts_pcm_free;
    local:
        *;
};
